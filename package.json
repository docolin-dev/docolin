    "shadcn-svelte": "^1.2.7",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "svelte-eslint-parser": "^1.6.1",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.7"
