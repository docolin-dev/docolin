# Neon Postgres connection string. Get from console.neon.tech.
# Use the "Pooled connection" (-pooler in hostname) for serverless/edge usage;
# the direct connection is fine for migrations and local dev.
DATABASE_URL=postgresql://user:password@host.eu-central-1.aws.neon.tech/dbname?sslmode=require

# WorkOS / AuthKit. Get from dashboard.workos.com (staging env for local dev).
# COOKIE_PASSWORD must be at least 32 characters; generate with: openssl rand -base64 32
WORKOS_CLIENT_ID=client_01XXXXXXXXXXXXXXXXXXXXXXXX
WORKOS_API_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXX
WORKOS_REDIRECT_URI=http://localhost:5173/callback
WORKOS_COOKIE_PASSWORD=replace-with-32-plus-char-random-string

# Read-only service tokens per git provider, used to bypass the anonymous
# rate limits when polling project sources for sync. Each provider gives
# ~1000-5000 requests/hr to a single token, vs ~60/hr anonymous.
#
# Scopes needed: public-repo read only. We never write back to the repo.
# Leave any blank to fall back to anonymous (rate-limited) for that
# provider.
#
# GitHub: github.com/settings/tokens (classic) or fine-grained PAT.
#   Scope: public_repo (or none / `repo:status` for fine-grained, contents:read).
GITHUB_TOKEN=
# GitLab: gitlab.com/-/user_settings/personal_access_tokens
#   Scope: read_api, read_repository.
GITLAB_TOKEN=
# Codeberg (and other Gitea instances we hit explicitly): codeberg.org/user/settings/applications
#   Scope: read:repository.
CODEBERG_TOKEN=
# Bitbucket: bitbucket.org/account/settings/app-passwords
#   Permissions: Repositories: Read.
BITBUCKET_TOKEN=

# Public base URL of the R2 media bucket. Used to build URLs the sync engine
# writes into doco bodies and the project_media_assets table.
# Dev:  https://media-dev.docolin.com  (bucket: docolin-media-dev)
# Prod: https://media.docolin.com      (bucket: docolin-media)
R2_PUBLIC_BASE=https://media-dev.docolin.com

# Shared secret for the cron-triggered sync endpoint at /api/cron/sync.
# Whichever scheduler (CF Cron Trigger or external) hits the endpoint with
# `Authorization: Bearer ${CRON_SECRET}`. Generate with: openssl rand -base64 32
CRON_SECRET=replace-with-32-plus-char-random-string

# Canonical public origin (scheme + host, no trailing slash). The sync drain
# self-kick fetches ${APP_ORIGIN}/api/sync/drain with the CRON_SECRET bearer;
# pinning it to a trusted value (instead of the request's Host) keeps the secret
# from being sent to a spoofed origin. Unset falls back to the request origin,
# which is fine for local dev. Prod: https://docolin.com
APP_ORIGIN=http://localhost:5173

# Cloudflare cache-purge credentials. After a sync publishes new doco versions,
# the sync engine calls CF's purge_cache API so cached HTML at the latest URL
# refreshes immediately instead of waiting for stale-while-revalidate. Both
# unset means purge is skipped silently (sync still succeeds; staleness window
# is bounded by the doco viewer's s-maxage).
#
# Zone id: shown on the docolin.com overview page in the CF dashboard.
# Token: dash.cloudflare.com/profile/api-tokens, create a custom token with
#   Zone permissions: Cache Purge, scoped to the docolin.com zone.
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_CACHE_PURGE_TOKEN=
STAMP_BUCKET_SECRET=
