# Neon Postgres connection string. Get from console.neon.tech.
# Use the "Pooled connection" (-pooler in hostname) for serverless/edge usage;
# the direct connection is fine for migrations and local dev.
DATABASE_URL=postgresql://user:password@host.eu-central-1.aws.neon.tech/dbname?sslmode=require

# WorkOS / AuthKit. Get from dashboard.workos.com (staging env for local dev).
# COOKIE_PASSWORD must be at least 32 characters; generate with: openssl rand -base64 32
WORKOS_CLIENT_ID=client_01XXXXXXXXXXXXXXXXXXXXXXXX
WORKOS_API_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXX
WORKOS_REDIRECT_URI=http://localhost:5173/callback
WORKOS_COOKIE_PASSWORD=replace-with-32-plus-char-random-string
