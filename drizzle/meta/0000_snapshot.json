      "definition": "\n    SELECT\n      d.id AS doco_id,\n      v.id AS version_id,\n      v.version_number,\n      v.kind,\n      v.type,\n      v.title,\n      v.description,\n      v.applies_to,\n      v.status,\n      v.language,\n      v.difficulty,\n      v.aliases,\n      v.body_text,\n      v.body_format,\n      v.up_votes_cache,\n      v.down_votes_cache,\n      v.embedding,\n      v.published_at\n    FROM docos d\n    INNER JOIN versions v ON v.id = d.latest_published_version_id\n  ",
